+/**
+ * ESM entry point for react-custom-scrollbars-2.
+ *
+ * WHY THIS FILE EXISTS (yarn patch workaround):
+ *
+ * Rolldown (used by Vite 8) wraps CJS modules via __toESM. When combined with
+ * Vite's optimizeDeps pre-bundling, this package ends up with TWO levels of
+ * nesting: the pre-bundled output's default export IS the CJS exports object
+ * (not the Scrollbars class itself), so consumers see:
+ *
+ *   import Scrollbars from 'react-custom-scrollbars-2';
+ *   // Scrollbars = { default: <class>, Scrollbars: <class> }   ← wrong!
+ *
+ * Providing a native ESM entry (this file) causes bundlers to skip the CJS
+ * pre-bundling path entirely. We still import the CJS module, but we handle
+ * both possible wrapping outcomes defensively.
+ *
+ * If this package ever ships its own ESM build this file should be removed.
+ */
+import cjsDefault from './index.js';
+
+// After __toESM processing, cjsDefault is EITHER:
+//   (a) the Scrollbars class directly (if __esModule:true is respected), OR
+//   (b) the full exports object { default: Scrollbars, Scrollbars: Scrollbars }
+const Scrollbars =
+  typeof cjsDefault === 'function'
+    ? cjsDefault
+    : (cjsDefault.default ?? cjsDefault.Scrollbars ?? cjsDefault);
+
+export default Scrollbars;
+export { Scrollbars };
