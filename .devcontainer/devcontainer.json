{
  "name": "Go",
  "image": "mcr.microsoft.com/devcontainers/go:1.25-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:2.1.0": {},
    "ghcr.io/devcontainers/features/docker-in-docker:3.1.0": {
      "version": "latest",
      "moby": true
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "esbenp.prettier-vscode"
      ]
    }
  },
  "appPort": [
    "4040:4040"
  ]
}